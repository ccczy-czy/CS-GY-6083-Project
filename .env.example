# Local Docker Compose: copy to .env and adjust if needed (compose reads env_file optionally — defaults are in docker-compose.yml).
# Railway: set SECRET_KEY in the dashboard; DATABASE_URL is injected when Postgres is linked.

SECRET_KEY=change-me-in-production

# Used only when DATABASE_URL is unset (local / Docker Compose):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Project Part 1
DB_USER=postgres
DB_PASSWORD=postpre

# DATABASE_URL=postgresql://user:pass@host:5432/dbname
